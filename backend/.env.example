API_HOST=0.0.0.0
API_PORT=8000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
# Intent routing only; use a small fast model so replies start sooner (set equal to OPENROUTER_DEFAULT_MODEL to use one model).
OPENROUTER_INTENT_MODEL=openai/gpt-4o-mini

DATABASE_URL=
DATABASE_ECHO_SQL=false
# Session pooler (e.g. Supabase :5432) is strict; only raise these if the DB allows.
DATABASE_POOL_SIZE=1
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_RECYCLE_SECONDS=3600
INIT_DB_SCHEMA_ON_STARTUP=false

JWT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/calendar/callback

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/notion/callback

FRONTEND_URL=http://localhost:3000

REDIS_URL=redis://localhost:6379/0

VOYAGEAI_API_KEY=
VOYAGEAI_MODEL=voyage-3

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

EDGE_TTS_VOICE=en-US-JennyNeural

# LangSmith (optional) — set tracing + API key to record LangGraph / LLM traces
# LANGSMITH_TRACING_V2=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=chief-of-staff
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional Gmail list tuning (matches config.py defaults)
# GMAIL_LIST_MAX_RESULTS=100
# GMAIL_LIST_MAX_TOTAL_MESSAGES=2000
# GMAIL_LIST_MAX_ENRICHED=500
# GMAIL_LIST_ENRICH_CONCURRENCY=10
